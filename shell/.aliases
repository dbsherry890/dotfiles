# ── Navigation ──────────────────────────────────────────────────────────────
alias ..='cd ..'

# ── Listing ─────────────────────────────────────────────────────────────────
alias ls="eza -1 --icons=always --group-directories-first --classify"
alias la="ls -aF"
alias ll="ls -lF"
alias l="la -F"

# ── Editing ─────────────────────────────────────────────────────────────────
alias bashrc="nvim ~/.bashrc"
alias zshrc="nvim ~/.zshrc"
alias dot="nvim ~/dotfiles"

# ── Git ──────────────────────────────────────────────────────────────────────
alias ga="git add ."
alias gb="git branch"
alias gc="git commit -m "
alias gp="git push"
alias gs="git status"

# ── Tmux ─────────────────────────────────────────────────────────────────────
alias ta='tmux attach -t'
alias tls='tmux ls'
alias tn='tmux new -s'

# ── Misc ──────────────────────────────────────────────────────────────────────
alias c="clear"
alias cm="cmatrix"
alias e="exit"
alias grep="grep --color=auto"
alias py=python3
alias src="source .venv/bin/activate"
# alias copilot="copilot -i 'Talk like a caveman, and use karpathy guidelines'"
# ── Obsidian ──────────────────────────────────────────────────────────────────────
alias notes="cd ~/obsidian"

# ── Work ──────────────────────────────────────────────────────────────────────
if grep -qi microsoft /proc/version 2>/dev/null; then
  alias pbcopy='clip.exe'
  alias ercot="cd ~/obsidian/ERCOT; nvim"
  alias win="cd /mnt/c/Users/DSHERRY/"
  alias winopen="explorer.exe"
  alias mdview='f() { pandoc "$1" -o /tmp/preview.html && explorer.exe "$(wslpath -w /tmp/preview.html)"; }; f'
  alias dc='docker compose'
fi

# ── Launch ──────────────────────────────────────────────────────────────────────
alias github="open https://github.com/dbsherry890"
alias rm='rm -i'
